# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=posi_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera una clave aleatoria larga, ej: openssl rand -base64 48
JWT_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA
JWT_ISSUER=POSI-API
JWT_AUDIENCE=POSI-App
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ── API ────────────────────────────────────────────────────────────────────────
API_PORT=5000

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
# Pasos para obtener el App Password de Gmail:
#   1. myaccount.google.com → Seguridad → Verificación en 2 pasos (debe estar activa)
#   2. Busca "Contraseñas de aplicaciones"
#   3. Crea una nueva app password → copia los 16 caracteres
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=tucorreo@gmail.com
SMTP_FROM_NAME=POSI

# URL pública de la API (sin / al final)
# Se usa en los links de verificación de correo
BASE_URL=https://tu-api.dokploy.com
